{
  "manifest_version": 3,
  "name": "Smart Fill - Inspector ADE",
  "version": "0.1.0",
  "description": "Scrapes Inspector ADE inspection Q&A + labeled photos, verifies answers with AI, and highlights matches/mismatches.",
  "permissions": ["sidePanel", "activeTab", "scripting", "storage", "unlimitedStorage", "tabs"],
  "host_permissions": [
    "https://www.inspectorade.com/*",
    "https://inspectorade.com/*",
    "https://archive.inspectorade.com/*",
    "http://localhost:3001/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "action": {
    "default_title": "Open Smart Fill - Inspector ADE"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.inspectorade.com/*",
        "https://inspectorade.com/*"
      ],
      "js": ["imageModal.js", "content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
